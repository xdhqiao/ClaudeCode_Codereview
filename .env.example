# MongoDB
MONGODB_URI=mongodb://localhost:27017
# Docker Compose uses this value and defaults to the bundled mongo service.
DOCKER_MONGODB_URI=mongodb://mongo:27017
MONGODB_DATABASE=ai_code_review

# Claude Agent SDK: direct Anthropic API
ANTHROPIC_API_KEY=

# Optional Anthropic-compatible enterprise/local gateway.
# The gateway must expose Anthropic Messages API endpoints such as /v1/messages.
ANTHROPIC_BASE_URL=
# Use this instead of ANTHROPIC_API_KEY when the gateway expects Authorization: Bearer.
ANTHROPIC_AUTH_TOKEN=

# Model and agent limits
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_EFFORT=high
CLAUDE_MAX_TURNS=12
CLAUDE_MAX_BUDGET_USD=2.0
CLAUDE_TIMEOUT_SECONDS=600
CLAUDE_RETRY_COUNT=2

# Worker
POLL_INTERVAL_SECONDS=5
WORKER_CONCURRENCY=2
REVIEW_CONCURRENCY_PER_TASK=2
TASK_LEASE_SECONDS=1800
TASK_MAX_ATTEMPTS=3
TASK_MAX_BUDGET_USD=20.0
MAX_FILES_PER_TASK=10000
MAX_AGENT_CALLS_PER_TASK=500

# Repository workspace and safety
WORKSPACE_ROOT=workspaces
KNOWLEDGE_ROOT=knowledge/standards
ALLOWED_LOCAL_REPO_ROOTS=
DOCKER_WORKSPACE_ROOT=/data/workspaces
DOCKER_KNOWLEDGE_ROOT=/app/knowledge/standards
DOCKER_ALLOWED_LOCAL_REPO_ROOTS=/data/repositories
# Required for remote repositories. Use explicit hosts; "*" deliberately allows all.
ALLOWED_REPO_HOSTS=github.com,gitlab.com
GIT_TIMEOUT_SECONDS=600
MAX_FILE_BYTES=1000000
FULL_SCAN_CHUNK_LINES=800
DIFF_CONTEXT_LINES=8
MAX_DIFF_BYTES=50000000
MAX_PROMPT_DIFF_CHARS=60000
MAX_STANDARD_CHARS=18000
MAX_STANDARD_RULES=20
MAX_ISSUES_PER_FILE=100

# API
API_HOST=0.0.0.0
API_PORT=8080
# Docker Compose host-side port; the container always listens on 8080.
HOST_API_PORT=8080
# Optional. When set, every endpoint except /health requires X-API-Key.
SERVICE_API_KEY=
LOG_LEVEL=INFO
